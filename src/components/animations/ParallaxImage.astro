---
interface Props {
  src: string;
  alt: string;
  class?: string;
}
const { src, alt, class: className = '' } = Astro.props;
---

<div class={`parallax-wrap ${className}`}>
  <img src={src} alt={alt} class="parallax-img" loading="lazy" decoding="async" />
</div>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  function initParallax() {
    document.querySelectorAll<HTMLElement>('.parallax-wrap:not([data-px])').forEach((wrap) => {
      wrap.dataset.px = '1';
      const img = wrap.querySelector<HTMLImageElement>('img');
      if (!img) return;

      // Parallax scrub — se reinicia automáticamente al entrar/salir
      gsap.to(img, {
        yPercent: -14,
        ease: 'none',
        scrollTrigger: {
          trigger: wrap,
          start: 'top bottom',
          end:   'bottom top',
          scrub: 1.8,
        },
      });

      // Fade de entrada y salida independiente
      ScrollTrigger.create({
        trigger: wrap,
        start: 'top 92%',
        end:   'bottom 5%',
        onEnter:     () => gsap.to(wrap, { opacity: 1, duration: 0.7, ease: 'power2.out' }),
        onEnterBack: () => gsap.to(wrap, { opacity: 1, duration: 0.7, ease: 'power2.out' }),
        onLeave:     () => gsap.to(wrap, { opacity: 0, duration: 0.4, ease: 'power2.in' }),
        onLeaveBack: () => gsap.to(wrap, { opacity: 0, duration: 0.4, ease: 'power2.in' }),
      });

      gsap.set(wrap, { opacity: 0 });
    });
  }

  document.addEventListener('animations:ready', initParallax);
</script>

<style>
  .parallax-wrap {
    overflow: hidden;
    border-radius: 4px;
    will-change: transform;
  }
  .parallax-img {
    width: 100%;
    height: 115%;
    object-fit: cover;
    display: block;
    transform-origin: center;
  }
</style>