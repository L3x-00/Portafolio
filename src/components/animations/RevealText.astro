---
interface Props {
  delay?: number;
  class?: string;
}
const { delay = 0, class: className = '' } = Astro.props;
---

<div class={`reveal-host ${className}`} data-delay={delay.toString()}>
  <slot />
  
</div>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  function initReveal() {
    document.querySelectorAll<HTMLElement>('.reveal-host:not([data-rv])').forEach((el) => {
      el.dataset.rv = '1';
      const delay = parseFloat(el.dataset.delay || '0');
      const inner = el.firstElementChild as HTMLElement;
      if (!inner) return;

      gsap.set(inner, { y: 40, opacity: 0 });

      gsap.to(inner, {
        y: 0,
        opacity: 1,
        duration: 0.8,
        delay,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 85%',      // Aparece al bajar
          end: 'bottom 15%',    // Empieza a desaparecer cuando su parte inferior toca el 15% de arriba (muy generoso)
          toggleActions: "play reverse play reverse",
        },
      });
    });
  }

  document.addEventListener('animations:ready', () => {
    console.log('Reveal recibió animations:ready');
    initReveal();
  });

  document.addEventListener('astro:page-load', () => {
    console.log('Reveal recibió astro:page-load');
    initReveal();
  });
</script>
