---
interface Props {
  delay?: number;
}
const { delay = 0 } = Astro.props;
---

<div class="reveal-text" data-reveal-delay={delay.toString()}>
  <slot />
</div>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  function initRevealText() {
    document.querySelectorAll<HTMLElement>('.reveal-text:not([data-rtext])').forEach((el) => {
      el.dataset.rtext = '1';
      const delay = parseFloat(el.getAttribute('data-reveal-delay') || '0');

      gsap.set(el, { y: 40, opacity: 0 });

      ScrollTrigger.create({
        trigger: el,
        start: 'top 90%',
        end:   'top 5%',
        onEnter: () =>
          gsap.to(el, { y: 0, opacity: 1, duration: 0.85, delay, ease: 'power3.out' }),
        onEnterBack: () =>
          gsap.to(el, { y: 0, opacity: 1, duration: 0.85, delay, ease: 'power3.out' }),
        onLeave: () =>
          gsap.to(el, { y: -30, opacity: 0, duration: 0.4, ease: 'power2.in' }),
        onLeaveBack: () =>
          gsap.to(el, { y: 40,  opacity: 0, duration: 0.4, ease: 'power2.in' }),
      });
    });
  }

  document.addEventListener('animations:ready', initRevealText);
</script>