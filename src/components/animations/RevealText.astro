---
interface Props {
  delay?: number;
  persist?: boolean;
}

const { delay = 0, persist = false } = Astro.props;
---

<div 
  class="reveal-text" 
  data-reveal-delay={delay} 
  data-reveal-persist={persist ? 'true' : undefined}
>
  <slot />
</div>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initRevealText() {
    const elements = document.querySelectorAll('.reveal-text');

    elements.forEach((el) => {
      const delay = parseFloat(el.getAttribute('data-reveal-delay') || '0');
      const isPersist = el.getAttribute('data-reveal-persist') === 'true';

      gsap.fromTo(
        el,
        { 
          opacity: 0, 
          y: 50 
        },
        {
          opacity: 1,
          y: 0,
          duration: 0.9,
          delay: delay,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: el,
            start: 'top 85%',
            end: 'top 30%',
            toggleActions: isPersist
              ? 'play none none reverse'
              : 'play reverse play reverse',
          }
        }
      );
    });

    ScrollTrigger.refresh();
  }

  // Orquestación: esperar a que Layout despache el evento centralizado
  document.addEventListener('animations:ready', () => {
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        initRevealText();
      });
    });
  });
</script>