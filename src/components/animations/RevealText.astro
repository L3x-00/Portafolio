---
interface Props {
  delay?: number;
}
const { delay = 0 } = Astro.props;
---

<div class="reveal-text" data-reveal-delay={delay.toString()}>
  <slot />
</div>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  function initRevealText() {
    document.querySelectorAll<HTMLElement>('.reveal-text:not([data-rtext])').forEach((el) => {
      el.dataset.rtext = '1';
      const delay = parseFloat(el.getAttribute('data-reveal-delay') || '0');

      gsap.fromTo(
        el,
        { opacity: 0, y: 40 },
        {
          opacity: 1,
          y: 0,
          duration: 0.85,
          delay,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: el,
            start: 'top 90%',
            // ✅ FIX: 'top -10%' = el elemento ya salió completamente del viewport por arriba
            // Con 'top 30%' el reverse se disparaba mientras el elemento AÚN ERA VISIBLE
            end: 'top -10%',
            toggleActions: 'play reverse play reverse',
          },
        }
      );
    });
  }

  // ✅ FIX: Solo un listener. Layout.astro dispara este evento en carga inicial Y navegación.
  document.addEventListener('animations:ready', initRevealText);
</script>