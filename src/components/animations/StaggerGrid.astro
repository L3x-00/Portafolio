---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div class={`stagger-grid ${className}`}>
  <slot />
</div>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  function initStagger() {
    document.querySelectorAll<HTMLElement>('.stagger-grid:not([data-sg])').forEach((grid) => {
      grid.dataset.sg = '1';
      const children = Array.from(grid.children) as HTMLElement[];
      if (!children.length) return;

      gsap.set(children, { y: 60, opacity: 0 });

      ScrollTrigger.create({
        trigger: grid,
        start: 'top 88%',
        end:   'bottom 8%',
        onEnter: () =>
          gsap.to(children, {
            y: 0, opacity: 1,
            duration: 0.65,
            stagger: 0.08,
            ease: 'power3.out',
          }),
        onEnterBack: () =>
          gsap.to(children, {
            y: 0, opacity: 1,
            duration: 0.65,
            stagger: 0.08,
            ease: 'power3.out',
          }),
        onLeave: () =>
          gsap.to(children, {
            y: -40, opacity: 0,
            duration: 0.4,
            stagger: 0.04,
            ease: 'power2.in',
          }),
        onLeaveBack: () =>
          gsap.to(children, {
            y: 60, opacity: 0,
            duration: 0.4,
            stagger: 0.04,
            ease: 'power2.in',
          }),
      });
    });
  }

  document.addEventListener('animations:ready', initStagger);
</script>