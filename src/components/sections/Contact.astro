---

<section id="contacto" class="contact">

  <!-- ── HEADER ─────────────────────────────────────────── -->
  <div class="contact__header container">
    <RevealText>
      <p class="contact__label">Contacto</p>
    </RevealText>
    <RevealText delay={0.08}>
      <h2 class="contact__title">
        Construyamos algo<br/>
        <span class="contact__title-accent">extraordinario.</span>
      </h2>
    </RevealText>
    <RevealText delay={0.16}>
      <p class="contact__sub">
        Disponible para proyectos freelance, posiciones full-time y colaboraciones.
        Elige el canal que prefieras — respondo rápido.
      </p>
    </RevealText>
  </div>

    <!-- ── CHANNEL CARDS (Estructura Embudo) ──────────────── -->
  <div class="contact__funnel-wrapper container">
    
    <!-- Fila 1: 4 tarjetas -->
    <div class="contact__row contact__row--top">
      {channels.slice(0, 4).map((ch) => (
        <a
          href={ch.href}
          target="_blank"
          rel="noopener noreferrer"
          class={`ch-card ${ch.featured ? 'ch-card--featured' : ''}`}
          data-channel
        >
          <div class="ch-card__top">
            <div class="ch-card__logo-group">
              <div class="ch-card__icon-wrap">
                <img src={ch.icon} alt={ch.label} class="ch-card__icon" loading="lazy" />
              </div>
              {/* Wordmark dinámico */}
              {ch.wordmark && (
                <img 
                  src={ch.wordmark} 
                  alt={`${ch.label} logo`} 
                  class={`ch-card__wordmark ${ch.wordmarkSize === 'lg' ? 'ch-card__wordmark--lg' : ''} ${ch.wordmarkSize === 'xl' ? 'ch-card__wordmark--xl' : ''}`}
                  loading="lazy" 
                />
              )}
            </div>
            <span class="ch-card__arrow">→</span>
          </div>

          <div class="ch-card__body">
            <p class="ch-card__label">{ch.label}</p>
            <p class="ch-card__value">{ch.value}</p>
            <p class="ch-card__desc">{ch.desc}</p>
          </div>

          <div class="ch-card__footer">
            <span class="ch-card__cta">{ch.cta}</span>
            {ch.featured && <span class="ch-card__badge">⚡ Directo</span>}
          </div>

          {/* Punto luminoso que persigue el cursor */}
          <span class="ch-card__glow" aria-hidden="true"></span>
        </a>
      ))}
    </div>

    <!-- Fila 2: 2 tarjetas centradas -->
    <div class="contact__row contact__row--bottom">
      {channels.slice(4).map((ch) => (
        <a
          href={ch.href}
          target="_blank"
          rel="noopener noreferrer"
          class={`ch-card ${ch.featured ? 'ch-card--featured' : ''}`}
          data-channel
        >
          <div class="ch-card__top">
            <div class="ch-card__logo-group">
              <div class="ch-card__icon-wrap">
                <img src={ch.icon} alt={ch.label} class="ch-card__icon" loading="lazy" />
              </div>
              {/* Wordmark dinámico */}
              {ch.wordmark && (
                <img 
                  src={ch.wordmark} 
                  alt={`${ch.label} logo`} 
                  class={`ch-card__wordmark ${ch.wordmarkSize === 'lg' ? 'ch-card__wordmark--lg' : ''} ${ch.wordmarkSize === 'xl' ? 'ch-card__wordmark--xl' : ''}`}
                  loading="lazy" 
                />
              )}
            </div>
            <span class="ch-card__arrow">→</span>
          </div>

          <div class="ch-card__body">
            <p class="ch-card__label">{ch.label}</p>
            <p class="ch-card__value">{ch.value}</p>
            <p class="ch-card__desc">{ch.desc}</p>
          </div>

          <div class="ch-card__footer">
            <span class="ch-card__cta">{ch.cta}</span>
            {ch.featured && <span class="ch-card__badge">⚡ Directo</span>}
          </div>

          {/* Punto luminoso que persigue el cursor */}
          <span class="ch-card__glow" aria-hidden="true"></span>
        </a>
      ))}
    </div>

  </div>

  <!-- ── TECH MARQUEE ───────────────────────────────────── -->
  <div class="contact__marquee-wrap" aria-label="Tecnologías que manejo">
    <div class="contact__marquee">
      <div class="marquee__track">
        {[...techIcons, ...techIcons].map((t, i) => (
          <div class="marquee__item" title={t.alt}>
            <img src={t.src} alt={t.alt} loading="lazy" />
            <span>{t.alt}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- ── FOOTER LINE ────────────────────────────────────── -->
  <div class="contact__footer container">
    <RevealText delay={0.05}>
      <div class="contact__footer-inner">
        <p class="contact__footer-copy">
          © {new Date().getFullYear()} · Hecho con Astro, Three.js & GSAP
        </p>
        <div class="contact__status">
          <span class="contact__status-dot"></span>
          <span>Abierto a oportunidades</span>
        </div>
      </div>
    </RevealText>
  </div>

</section>

<!-- SCRIPT UNIFICADO (Visibilidad + Tilt + Glow) -->
<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  function initContact() {
    const cards = document.querySelectorAll<HTMLElement>('[data-channel]');
    if (!cards.length) return;

    gsap.set(cards, { opacity: 1, y: 0, scale: 1 });

    ScrollTrigger.batch(cards, {
      onEnter: (batch) => {
        gsap.fromTo(batch, 
          { opacity: 0, y: 40, scale: 0.95 },
          { opacity: 1, y: 0, scale: 1, duration: 0.7, stagger: 0.08, ease: 'power3.out' }
        );
      },
      start: 'top 90%',
      once: true
    });

    cards.forEach((card) => {
      const glow = card.querySelector<HTMLElement>('.ch-card__glow');

      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        
        const tiltX = ((y / rect.height) - 0.5) * -10;
        const tiltY = ((x / rect.width) - 0.5) * 10;

        gsap.to(card, { 
          rotateX: tiltX, 
          rotateY: tiltY, 
          duration: 0.3, 
          ease: 'power1.out', 
          transformPerspective: 800 
        });

        if (glow) {
          const px = (x / rect.width) * 100;
          const py = (y / rect.height) * 100;
          glow.style.background = `radial-gradient(circle 120px at ${px}% ${py}%, rgba(0,240,255,0.2), rgba(191,0,255,0.05) 40%, transparent 70%)`;
        }
      });

      card.addEventListener('mouseleave', () => {
        gsap.to(card, { 
          rotateX: 0, 
          rotateY: 0, 
          duration: 0.6, 
          ease: 'elastic.out(1, 0.5)' 
        });
        if (glow) glow.style.background = 'none';
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initContact);
</script>

<style>
  /* ── SECTION ──────────────────────────────────────────── */
  .contact {
    padding: 8rem 0 0;
    overflow: hidden;
  }
  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ── HEADER ───────────────────────────────────────────── */
  .contact__header {
    text-align: center;
    margin-bottom: 4.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }
  .contact__label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    border: 1px solid rgba(0,240,255,0.2);
    padding: 0.3rem 1rem;
    border-radius: 100px;
    display: inline-block;
  }
  .contact__title {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5.5vw, 4.2rem);
    font-weight: 700;
    line-height: 1.08;
    color: var(--color-text);
  }
  .contact__title-accent {
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-alt) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .contact__sub {
    font-size: 1.05rem;
    color: var(--color-muted);
    line-height: 1.75;
    max-width: 520px;
  }

    /* ━━━ LAYOUT EMBUDO (Flexbox) ━━━ */
  .contact__funnel-wrapper {
    margin-bottom: 3rem;
  }
  
  .contact__row {
    display: flex;
    justify-content: center; /* Centra las tarjetas horizontalmente */
    gap: 1.25rem;
    flex-wrap: wrap; /* Si la pantalla es pequeña, bajan de fila solas */
  }

  .contact__row--top {
    margin-bottom: 1.25rem; /* Espacio entre la fila de 4 y la de 2 */
  }

  /* ── CHANNEL CARD (Rediseño Profesional) ──────────── */
  .ch-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 1.5rem 1.25rem;
    background: linear-gradient(160deg, rgba(255,255,255,0.03) 0%, var(--color-surface) 100%);
    border: 1px solid var(--color-border);
    border-radius: 18px; 
    text-decoration: none;
    overflow: hidden;
    transform-style: preserve-3d;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    will-change: transform;
  }
  .ch-card:hover {
    transform: translateY(-6px);
    border-color: rgba(0,240,255,0.4);
    box-shadow: 
      0 20px 40px rgba(0, 0, 0, 0.4),
      0 0 30px rgba(0, 240, 255, 0.08);
  }
  .ch-card--featured {
    border-color: rgba(0,240,255,0.25);
    background: linear-gradient(160deg, rgba(0,240,255,0.06) 0%, var(--color-surface) 60%);
  }
  .ch-card--featured:hover {
    border-color: rgba(0,240,255,0.6);
    box-shadow: 
      0 24px 48px rgba(0, 0, 0, 0.5),
      0 0 40px rgba(0, 240, 255, 0.12);
  }

  /* Punto luminoso dinámico (Glow) */
  .ch-card__glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    border-radius: 18px;
    transition: background 0.1s ease;
  }

  /* Z-index para contenido sobre el glow */
  .ch-card__top,
  .ch-card__body,
  .ch-card__footer { position: relative; z-index: 1; }

  .ch-card__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  /* ━━━ CONTENEDOR ICONO + WORDMARK ━━━ */
  .ch-card__logo-group {
    display: flex;
    align-items: center;
    gap: 0.5rem; /* Espacio entre icono y wordmark */
  }

  .ch-card__icon-wrap {
    width: 44px;
    height: 44px;
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 9px;
    transition: background 0.3s, border-color 0.3s, box-shadow 0.3s;
    flex-shrink: 0;
  }
  .ch-card:hover .ch-card__icon-wrap {
    background: rgba(0,240,255,0.1);
    border-color: rgba(0,240,255,0.4);
    box-shadow: 0 0 15px rgba(0,240,255,0.15);
  }
  .ch-card__icon {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    transition: filter 0.3s, transform 0.3s;
  }
  .ch-card:hover .ch-card__icon {
    transform: scale(1.1);
    filter: drop-shadow(0 0 8px rgba(0,240,255,0.5));
  }

  /* ━━━ WORDMARKS ━━━ */
  .ch-card__wordmark {
    height: 18px; /* Tamaño base estándar (GitHub, Facebook) */
    max-width: 70px;
    width: auto;
    object-fit: contain;
    opacity: 0;
    transform: translateX(-8px);
    filter: brightness(0) invert(1); /* Blanco en dark mode */
    transition: opacity 0.3s ease, transform 0.3s ease;
    flex-shrink: 0;
  }

  /* Variante Large para wordmarks pequeños (Servi, LinkedIn, Gmail, WhatsApp) */
  .ch-card__wordmark--lg {
    height: 24px; /* 👈 Más alto */
    max-width: 100px; /* 👈 Más ancho para que respiren */
  }
  .ch-card__wordmark--xl {
    height: 28px; /* 👈 Aún más alto */
    max-width: 120px; /* 👈 Aún más ancho */
  }

  .ch-card:hover .ch-card__wordmark {
    opacity: 0.8;
    transform: translateX(0);
  }

  .ch-card__arrow {
    font-family: var(--font-mono);
    font-size: 1.2rem;
    color: var(--color-muted);
    transition: color 0.2s, transform 0.25s;
  }
  .ch-card:hover .ch-card__arrow {
    color: var(--color-accent);
    transform: translate(4px, -4px);
  }

  .ch-card__body { display: flex; flex-direction: column; gap: 0.25rem; flex: 1; }
  .ch-card__label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .ch-card__value {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    word-break: break-all;
    line-height: 1.3;
  }
  .ch-card__desc {
    font-size: 0.8rem;
    color: var(--color-muted);
    margin-top: 0.15rem;
  }

  .ch-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }
  .ch-card__cta {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    transition: letter-spacing 0.25s;
  }
  .ch-card:hover .ch-card__cta { letter-spacing: 0.14em; }

  .ch-card__badge {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.06em;
    color: var(--color-accent-green);
    background: rgba(57, 255, 20, 0.08);
    border: 1px solid rgba(57, 255, 20, 0.2);
    padding: 0.18rem 0.55rem;
    border-radius: 100px;
  }

  /* ── TECH MARQUEE ─────────────────────────────────────── */
  .contact__marquee-wrap {
    position: relative;
    padding: 2.5rem 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
    margin-bottom: 0;
  }
  .contact__marquee-wrap::before,
  .contact__marquee-wrap::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 10rem;
    z-index: 2;
    pointer-events: none;
  }
  .contact__marquee-wrap::before { left: 0; background: linear-gradient(90deg, var(--color-bg), transparent); }
  .contact__marquee-wrap::after { right: 0; background: linear-gradient(-90deg, var(--color-bg), transparent); }

  .contact__marquee { overflow: hidden; }
  .marquee__track {
    display: flex;
    gap: 2.5rem;
    width: max-content;
    animation: marquee-scroll 38s linear infinite;
  }
  .marquee__track:hover { animation-play-state: paused; }

  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .marquee__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.55rem;
    cursor: default;
    transition: transform 0.2s;
    flex-shrink: 0;
  }
  .marquee__item:hover { transform: translateY(-4px); }
  .marquee__item img {
    width: 28px;
    height: 28px;
    object-fit: contain;
    filter: grayscale(0.25) opacity(0.7);
    transition: filter 0.25s;
  }
  .marquee__item:hover img {
    filter: grayscale(0) opacity(1) drop-shadow(0 0 8px rgba(0,240,255,0.35));
  }
  .marquee__item span {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    text-transform: uppercase;
    white-space: nowrap;
  }

  /* ── FOOTER LINE ──────────────────────────────────────── */
  .contact__footer { padding: 2rem 0; }
  .contact__footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .contact__footer-copy {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-muted);
    letter-spacing: 0.04em;
  }
  .contact__status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-muted);
    letter-spacing: 0.04em;
  }
  .contact__status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-accent-green);
    animation: blink-dot 2s ease-in-out infinite;
  }
  @keyframes blink-dot {
    0%, 100% { opacity: 1; box-shadow: 0 0 6px var(--color-accent-green); }
    50%       { opacity: 0.35; box-shadow: none; }
  }
</style>