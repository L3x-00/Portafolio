---
import SectionTitle from '../ui/SectionTitle.astro';
import Button from '../ui/Button.astro';
import RevealText from '../animations/RevealText.astro';
---

<section id="contacto" class="contact section-pad">
  <div class="container">
    <div class="contact-inner">
      <SectionTitle label="Contacto" title="¿Tienes un proyecto?" align="center" />

      <RevealText delay={0.1}>
        <p class="contact-desc">
          Estoy disponible para proyectos freelance, colaboraciones y posiciones
          a tiempo completo. Si tienes una idea que quieres convertir en una
          experiencia extraordinaria, hablemos.
        </p>
      </RevealText>

      <RevealText delay={0.2}>
        <div class="contact-actions">
          <Button 
            text="Escríbeme"
            href="mailto:alexander.huanaco@correo.com"
            variant="ghost"
          />

          <a
            class="contact-linkedin"
            href="https://www.linkedin.com/in/alexander-huanaco-quispe-0290362a1/"
            target="_blank"
          >
            LinkedIn →
          </a>
        </div>
      </RevealText>

      <div class="contact-line"></div>
    </div>
  </div>
</section>

<style>
  .section-pad { padding: 7rem 0; }
  .container   { max-width: 1280px; margin: 0 auto; padding: 0 2rem; }

  .contact-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
  }

  .contact-desc {
    font-size: 1.0625rem;
    color: var(--color-muted);
    line-height: 1.8;
  }

  .contact-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .contact-line {
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-accent), transparent);
    margin-top: 2rem;
    opacity: 0.3;
  }
  .contact-actions {
  display: flex;
  gap: 1.5rem;
  justify-content: center;
  align-items: center;
}

/* botón principal sin bloque sólido */
button, .btn-primary {
  background: transparent;
  border: 1px solid var(--color-accent);
  color: var(--color-text);
  transition: all 0.3s var(--ease-smooth);
}

button:hover {
  background: var(--color-accent);
  color: #050505;
  transform: translateY(-2px);
}

/* LinkedIn como link de bajo peso */
.contact-linkedin {
  font-family: var(--font-mono);
  font-size: 0.85rem;
  color: var(--color-muted);
  text-decoration: none;
  opacity: 0.7;
  transition: all 0.3s ease;
}

.contact-linkedin:hover {
  color: var(--color-accent);
  opacity: 1;
  transform: translateX(4px);
}
</style>