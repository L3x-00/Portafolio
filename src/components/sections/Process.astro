---
import SectionTitle from '../ui/SectionTitle.astro';
import RevealText from '../animations/RevealText.astro';

const steps = [
  {
    num:   '01',
    title: 'Descubrimiento',
    desc:  'Entiendo el negocio, al usuario y los objetivos antes de escribir una sola línea de código.',
    icon:  '🔍',
  },
  {
    num:   '02',
    title: 'Diseño & Sistema',
    desc:  'Creo el sistema de diseño, componentes y la arquitectura visual en Figma con tokens definidos.',
    icon:  '🎨',
  },
  {
    num:   '03',
    title: 'Desarrollo',
    desc:  'Código limpio, tipado y accesible. Cada animación tiene propósito y cada byte está optimizado.',
    icon:  '⚡',
  },
  {
    num:   '04',
    title: 'Lanzamiento',
    desc:  'Deploy en edge networks, tests de performance y soporte post-lanzamiento para que todo vuele.',
    icon:  '🚀',
  },
];
---

<section id="proceso" class="process section-pad">
  <div class="container">
    <SectionTitle label="Mi proceso" title="Cómo trabajo." />

    <div class="process-grid">
      {steps.map((step, i) => (
        <RevealText delay={i * 0.1}>
          <div class="process-step">
            <div class="process-step__header">
              <span class="process-step__num">{step.num}</span>
              <span class="process-step__icon">{step.icon}</span>
            </div>
            <h3 class="process-step__title">{step.title}</h3>
            <p class="process-step__desc">{step.desc}</p>
            {i < steps.length - 1 && <div class="process-step__connector"></div>}
          </div>
        </RevealText>
      ))}
    </div>
  </div>
</section>

<style>
  .section-pad { padding: 7rem 0; }
  .container   { max-width: 1280px; margin: 0 auto; padding: 0 2rem; }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
    margin-top: 4rem;
    position: relative;
  }

  .process-step {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 2rem 1.5rem;
    position: relative;
    transition: border-color 0.3s;
  }
  .process-step:hover { border-color: rgba(0,240,255,0.25); }

  .process-step__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }
  .process-step__num {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: var(--color-accent);
  }
  .process-step__icon { font-size: 1.5rem; }

  .process-step__title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }
  .process-step__desc {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.7;
  }

  .process-step__connector {
    position: absolute;
    top: 50%;
    right: -0.75rem;
    width: 1.5rem;
    height: 1px;
    background: linear-gradient(90deg, var(--color-accent), transparent);
    z-index: 1;
  }
  @media (max-width: 768px) { .process-step__connector { display: none; } }
</style>src/components/sections/Contact.astro