---
import { projects } from '../../data/projects';
import SectionTitle from '../ui/SectionTitle.astro';
import StaggerGrid from '../animations/StaggerGrid.astro';
---

<section id="proyectos" class="projects section-pad">
  <div class="container">
    <SectionTitle label="Trabajo" title="Proyectos seleccionados." />

    <StaggerGrid class="projects-grid">
      {projects.map((project) => (
        <a href={`/proyecto/${project.slug}`} class="project-card" data-tilt>
          <div class="project-card__image-wrap">
            <img
              src={project.image}
              alt={project.title}
              class="project-card__image"
              loading="lazy"
              decoding="async"
            />
            <div class="project-card__overlay"></div>
          </div>

          <div class="project-card__body">
            <div class="project-card__meta">
              <span class="project-card__year">{project.year}</span>
              <div class="project-card__tags">
                {project.tags.slice(0, 3).map(tag => (
                  <span class="project-card__tag">{tag}</span>
                ))}
              </div>
            </div>
            <h3 class="project-card__title">{project.title}</h3>
            <p class="project-card__desc">{project.description}</p>
            <span class="project-card__cta">Ver caso →</span>
          </div>

          {/* Efecto de luz interna al hacer hover */}
          <div class="project-card__spotlight" aria-hidden="true"></div>
        </a>
      ))}
    </StaggerGrid>
  </div>
</section>

<!-- SCRIPT UNIFICADO (Tilt + Spotlight) -->
<script>
  import { gsap } from 'gsap';

  function initProjectTilt() {
    const cards = document.querySelectorAll<HTMLElement>('.project-card');
    
    cards.forEach((card) => {
      if (card.dataset.tiltActive) return;
      card.dataset.tiltActive = '1';
      
      const spotlight = card.querySelector<HTMLElement>('.project-card__spotlight');

      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        
        // Efecto 3D Tilt
        const tiltX = ((y / rect.height) - 0.5) * -8; // Menos inclinación que contacto para no marear
        const tiltY = ((x / rect.width) - 0.5) * 8;

        gsap.to(card, {
          rotateX: tiltX,
          rotateY: tiltY,
          duration: 0.2,
          ease: 'power2.out',
          transformPerspective: 1000,
        });

        // Efecto Spotlight (Luz que sigue al ratón)
        if (spotlight) {
          const px = (x / rect.width) * 100;
          const py = (y / rect.height) * 100;
          spotlight.style.background = `radial-gradient(circle 200px at ${px}% ${py}%, rgba(0,240,255,0.08), transparent 80%)`;
        }
      });

      card.addEventListener('mouseleave', () => {
        // Volver a la posición con efecto elástico suave
        gsap.to(card, {
          rotateX: 0,
          rotateY: 0,
          duration: 0.6,
          ease: 'elastic.out(1, 0.5)',
        });
        if (spotlight) spotlight.style.background = 'none';
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initProjectTilt);
</script>

<style>
  .section-pad { padding: 7rem 0; }
  .container   { max-width: 1280px; margin: 0 auto; padding: 0 2rem; }

  /* ━━━ TARJETA DE PROYECTO ━━━ */
  .project-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 18px; /* Bordes redondeados premium */
    overflow: hidden;
    text-decoration: none;
    transform-style: preserve-3d;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    cursor: pointer;
  }

  .project-card:hover {
    transform: translateY(-8px);
    border-color: rgba(0,240,255,0.35);
    box-shadow: 
      0 24px 48px rgba(0, 0, 0, 0.5),
      0 0 30px rgba(0, 240, 255, 0.07);
  }

  /* Spotlight: Capa de luz que sigue al cursor */
  .project-card__spotlight {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
    border-radius: 18px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .project-card:hover .project-card__spotlight {
    opacity: 1;
  }

  /* Imagen */
  .project-card__image-wrap {
    position: relative;
    aspect-ratio: 16/10;
    overflow: hidden;
  }
  .project-card__image {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94), filter 0.6s ease;
  }
  .project-card:hover .project-card__image {
    transform: scale(1.08); /* Zoom suave y elegante */
    filter: brightness(1.1);
  }
  .project-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(5,5,5,0.8) 0%, transparent 50%);
    z-index: 1;
  }

  /* Cuerpo */
  .project-card__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
    position: relative;
    z-index: 3; /* Por encima del spotlight */
  }

  .project-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .project-card__year {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
    letter-spacing: 0.06em;
  }

  .project-card__tags { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .project-card__tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    border: 1px solid rgba(0,240,255,0.25);
    background: rgba(0,240,255,0.05);
    padding: 0.2rem 0.6rem;
    border-radius: 6px; /* Tags redondeados */
    transition: background 0.2s, border-color 0.2s;
  }
  .project-card:hover .project-card__tag {
    border-color: rgba(0,240,255,0.4);
    background: rgba(0,240,255,0.1);
  }

  .project-card__title {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.2;
  }
  .project-card__desc {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.6;
    flex: 1;
  }

  .project-card__cta {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-accent);
    letter-spacing: 0.04em;
    transition: letter-spacing 0.25s ease;
  }
  .project-card:hover .project-card__cta { 
    letter-spacing: 0.12em; 
  }
</style>