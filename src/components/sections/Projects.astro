---
import { projects } from '../../data/projects';
import SectionTitle from '../ui/SectionTitle.astro';
import StaggerGrid from '../animations/StaggerGrid.astro';
---

<section id="proyectos" class="projects section-pad">
  <div class="container">
    <SectionTitle label="Trabajo" title="Proyectos seleccionados." />

    <StaggerGrid class="projects-grid">
      {projects.map((project) => (
        <a href={`/proyecto/${project.slug}`} class="project-card">
          <div class="project-card__image-wrap">
            <img
              src={project.image}
              alt={project.title}
              class="project-card__image"
              loading="lazy"
              decoding="async"
            />
            <div class="project-card__overlay"></div>
          </div>

          <div class="project-card__body">
            <div class="project-card__meta">
              <span class="project-card__year">{project.year}</span>
              <div class="project-card__tags">
                {project.tags.slice(0, 3).map(tag => (
                  <span class="project-card__tag">{tag}</span>
                ))}
              </div>
            </div>
            <h3 class="project-card__title">{project.title}</h3>
            <p class="project-card__desc">{project.description}</p>
            <span class="project-card__cta">Ver caso →</span>
          </div>
        </a>
      ))}
    </StaggerGrid>
  </div>
</section>

<style>
  .section-pad { padding: 7rem 0; }
  .container   { max-width: 1280px; margin: 0 auto; padding: 0 2rem; }

  .project-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    overflow: hidden;
    text-decoration: none;
    transition: border-color 0.3s, transform 0.3s;
    cursor: pointer;
  }
  .project-card:hover {
    border-color: rgba(0,240,255,0.3);
    transform: translateY(-4px);
  }
  .project-card:hover .project-card__image { transform: scale(1.04); }

  .project-card__image-wrap {
    position: relative;
    aspect-ratio: 16/10;
    overflow: hidden;
  }
  .project-card__image {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .project-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(5,5,5,0.6) 0%, transparent 60%);
  }

  .project-card__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .project-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .project-card__year {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
    letter-spacing: 0.06em;
  }

  .project-card__tags { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .project-card__tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    border: 1px solid rgba(0,240,255,0.25);
    padding: 0.2rem 0.6rem;
    border-radius: 2px;
  }

  .project-card__title {
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.2;
  }
  .project-card__desc {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.6;
    flex: 1;
  }

  .project-card__cta {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-accent);
    letter-spacing: 0.04em;
    transition: letter-spacing 0.2s;
  }
  .project-card:hover .project-card__cta { letter-spacing: 0.12em; }
</style>