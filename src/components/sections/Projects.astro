---
import { projects } from '../../data/projects';
import SectionTitle from '../ui/SectionTitle.astro';
import StaggerGrid from '../animations/StaggerGrid.astro';
---

<section id="proyectos" class="projects section-pad">
  <div class="container">
    <SectionTitle label="Trabajo" title="Proyectos seleccionados." />

    <StaggerGrid class="projects-grid">
      {projects.map((project) => (
        <a href={`/proyecto/${project.slug}`} class="project-card" data-tilt>
          <div class="project-card__image-wrap">
            <img
              src={project.image}
              alt={project.title}
              class="project-card__image"
              loading="lazy"
              decoding="async"
            />
            <div class="project-card__overlay"></div>
          </div>

          <div class="project-card__body">
            <div class="project-card__meta">
              <span class="project-card__year">{project.year}</span>
              {/* ━━━ TAGS CON SVG ICONS ━━━ */}
              <div class="project-card__tags">
                {project.tags.slice(0, 5).map(tag => (
                  <div class="project-tag" title={tag}>
                    <img src={`/icons/${tag}-color.svg`} alt={tag} />
                  </div>
                ))}
              </div>
            </div>
            <h3 class="project-card__title">{project.title}</h3>
            <p class="project-card__desc">{project.description}</p>
            <span class="project-card__cta">Ver caso →</span>
          </div>

          {/* Efecto de luz interna al hacer hover */}
          <div class="project-card__spotlight" aria-hidden="true"></div>
        </a>
      ))}
    </StaggerGrid>
  </div>
</section>

<!-- SCRIPT UNIFICADO (Tilt + Spotlight + Enter/Leave Cycle) -->
<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  function initProjectAnimations() {
    const cards = document.querySelectorAll<HTMLElement>('.project-card');
    if (!cards.length) return;

    // ── 1. Animación de Entrada / Salida (Scroll Cycle) ──
    // Aseguramos el estado inicial para GSAP
    gsap.set(cards, { opacity: 0, y: 60 });

    cards.forEach((card) => {
      ScrollTrigger.create({
        trigger: card,
        start: 'top 88%',
        end: 'bottom 15%',
        onEnter: () => {
          gsap.to(card, { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' });
        },
        onEnterBack: () => {
          gsap.to(card, { opacity: 1, y: 0, duration: 0.5, ease: 'power3.out' });
        },
        onLeave: () => {
          gsap.to(card, { opacity: 0, y: -40, duration: 0.35, ease: 'power2.in' });
        },
        onLeaveBack: () => {
          gsap.to(card, { opacity: 0, y: 60, duration: 0.35, ease: 'power2.in' });
        },
      });
    });

    // ── 2. Efecto 3D Tilt + Spotlight (Solo en Escritorio) ──
    const isDesktop = window.matchMedia('(min-width: 768px)').matches;

    if (isDesktop) {
      cards.forEach((card) => {
        if (card.dataset.tiltActive) return;
        card.dataset.tiltActive = '1';
        
        const spotlight = card.querySelector<HTMLElement>('.project-card__spotlight');

        card.addEventListener('mousemove', (e) => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          
          const tiltX = ((y / rect.height) - 0.5) * -6; 
          const tiltY = ((x / rect.width) - 0.5) * 6;

          gsap.to(card, {
            rotateX: tiltX,
            rotateY: tiltY,
            duration: 0.2,
            ease: 'power2.out',
            transformPerspective: 1000,
          });

          if (spotlight) {
            const px = (x / rect.width) * 100;
            const py = (y / rect.height) * 100;
            spotlight.style.background = `radial-gradient(circle 200px at ${px}% ${py}%, rgba(0,240,255,0.08), transparent 80%)`;
          }
        });

        card.addEventListener('mouseleave', () => {
          gsap.to(card, {
            rotateX: 0,
            rotateY: 0,
            duration: 0.6,
            ease: 'elastic.out(1, 0.5)',
          });
          if (spotlight) spotlight.style.background = 'none';
        });
      });
    }
  }

  document.addEventListener('DOMContentLoaded', initProjectAnimations);
</script>

<style>
  .section-pad { padding: 7rem 0; }
  .container   { max-width: 1280px; margin: 0 auto; padding: 0 2rem; }

  /* ━━━ TARJETA DE PROYECTO ━━━ */
  .project-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 18px;
    overflow: hidden;
    text-decoration: none;
    transform-style: preserve-3d;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    cursor: pointer;
    /* Forzamos visibilidad inicial para evitar FOUC, GSAP controlará el estado */
    opacity: 1; 
  }

  .project-card:hover {
    transform: translateY(-8px);
    border-color: rgba(0,240,255,0.35);
    box-shadow: 
      0 24px 48px rgba(0, 0, 0, 0.5),
      0 0 30px rgba(0, 240, 255, 0.07);
  }

  /* Spotlight: Capa de luz que sigue al cursor */
  .project-card__spotlight {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
    border-radius: 18px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .project-card:hover .project-card__spotlight {
    opacity: 1;
  }

  /* Imagen */
  .project-card__image-wrap {
    position: relative;
    aspect-ratio: 16/10;
    overflow: hidden;
  }
  .project-card__image {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94), filter 0.6s ease;
  }
  .project-card:hover .project-card__image {
    transform: scale(1.08);
    filter: brightness(1.1);
  }
  .project-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(5,5,5,0.8) 0%, transparent 50%);
    z-index: 1;
  }

  /* Cuerpo */
  .project-card__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
    position: relative;
    z-index: 3;
  }

  .project-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .project-card__year {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
    letter-spacing: 0.06em;
  }

  /* ━━━ NUEVOS TAGS CON SVG ━━━ */
  .project-card__tags { 
    display: flex; 
    gap: 0.4rem; 
    flex-wrap: wrap; 
  }

  .project-tag {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: rgba(0, 0, 0, 0.5); /* Fondo negro semitransparente */
    border: 1px solid rgba(255, 255, 255, 0.06); /* Borde negro delgado casi invisible */
    border-radius: 6px;
    padding: 5px;
    transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .project-tag img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: grayscale(0.6) brightness(0.8); /* Apagados por defecto */
    transition: filter 0.3s ease, transform 0.3s ease;
  }

  /* Animación del Tag al hover de la tarjeta completa */
  .project-card:hover .project-tag {
    background: rgba(0, 0, 0, 0.7);
    border-color: rgba(255, 255, 255, 0.12);
    transform: translateY(-2px); /* Saltito suave */
  }

  .project-card:hover .project-tag img {
    filter: grayscale(0) brightness(1.2) drop-shadow(0 0 4px currentColor); /* Color brillante */
  }

  /* Hover individual del tag */
  .project-tag:hover {
    border-color: rgba(0, 240, 255, 0.4) !important;
    box-shadow: 0 0 10px rgba(0, 240, 255, 0.15);
    transform: translateY(-3px) scale(1.1) !important;
  }

  .project-card__title {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.2;
  }
  .project-card__desc {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.6;
    flex: 1;
  }

  .project-card__cta {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-accent);
    letter-spacing: 0.04em;
    transition: letter-spacing 0.25s ease;
  }
  .project-card:hover .project-card__cta { 
    letter-spacing: 0.12em; 
  }
</style>