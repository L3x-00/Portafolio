---
import { stack } from '../../data/stack';
import SectionTitle from '../ui/SectionTitle.astro';

const categories = [
  { key: 'Frontend',  title: 'Frontend' },
  { key: 'Backend',   title: 'Backend & BD' },
  { key: 'Diseño',    title: 'Diseño' },
  { key: 'IA',        title: 'IA' },
  { key: 'Cloud',     title: 'Cloud & Deploy' },
];
---

<section id="stack" class="stack-section section-pad">
  <div class="container">
    <SectionTitle label="Herramientas" title="Mi stack tecnológico." align="center" />

    <div class="stack-row">
      {categories.map((cat) => {
        const items = stack.filter(item => item.category === cat.key);
        if (!items.length) return null;
        return (
          <div class="stack-col" data-stack-col>
            <div class="stack-col__header">
              <h3 class="stack-col__title">{cat.title}</h3>
              <button class="stack-col__btn" data-stack-btn aria-expanded="false">
                Ver todo
              </button>
            </div>

            <div class="stack-col__grid" data-stack-grid>
              {items.map((item) => (
                <div class="stack-item" style={`--c: ${item.color}`}>
                  <div class="stack-item__icon">
                    <img src={item.icon} alt={item.name} loading="lazy" />
                  </div>
                  <span class="stack-item__name">{item.name}</span>
                  <span class="stack-item__level">{item.level}</span>
                </div>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // ── Tipos de estado por columna ──────────────────────────
  // 'hidden'    → invisible, aún no entró al viewport
  // 'entering'  → animando entrada
  // 'expanded'  → visible y expandido (espera 2s)
  // 'collapsing'→ animando colapso
  // 'collapsed' → colapsado, botón visible
  // 'expanding' → usuario pulsó "Ver todo", expandiendo

  function initStack() {
    const cols = document.querySelectorAll<HTMLElement>('[data-stack-col]:not([data-init])');
    if (!cols.length) return;

    cols.forEach((col) => {
      col.dataset.init = '1';

      const grid  = col.querySelector<HTMLElement>('[data-stack-grid]')!;
      const btn   = col.querySelector<HTMLButtonElement>('[data-stack-btn]')!;
      const cards = Array.from(grid.querySelectorAll<HTMLElement>('.stack-item'));

      // Estado interno de esta columna
      let state: 'hidden' | 'entering' | 'expanded' | 'collapsing' | 'collapsed' | 'expanding' = 'hidden';
      let collapseTimeout: ReturnType<typeof setTimeout> | null = null;

      // ── Helpers ─────────────────────────────────────────

      function clearTimer() {
        if (collapseTimeout) { clearTimeout(collapseTimeout); collapseTimeout = null; }
      }

      function setGridOpen() {
        // Expande sin animación (estado inicial para medir)
        gsap.set(grid, { overflow: 'hidden', maxHeight: 'none', opacity: 1 });
      }

      function resetToHidden() {
        clearTimer();
        gsap.killTweensOf([...cards, grid, btn]);
        state = 'hidden';
        gsap.set(cards, { y: 20, opacity: 0, scale: 0.94 });
        gsap.set(grid,  { overflow: 'hidden', maxHeight: 'none', opacity: 1 });
        gsap.set(btn,   { opacity: 0, visibility: 'hidden' });
        btn.setAttribute('aria-expanded', 'false');
        btn.textContent = 'Ver todo';
      }

      // ── Ciclo de entrada ─────────────────────────────────

      function enterCycle() {
        if (state === 'entering' || state === 'expanded') return;
        clearTimer();

        // Si estaba colapsado por el usuario, re-expandir primero silenciosamente
        setGridOpen();
        gsap.set(btn, { opacity: 0, visibility: 'hidden' });

        state = 'entering';

        gsap.fromTo(cards,
          { y: 20, opacity: 0, scale: 0.94 },
          {
            y: 0, opacity: 1, scale: 1,
            duration: 0.5,
            stagger: { amount: 0.3, from: 'start' },
            ease: 'power3.out',
            onComplete: () => {
              if (state !== 'entering') return; // fue interrumpido
              state = 'expanded';

              // Tras 2s → colapso automático
              collapseTimeout = setTimeout(() => {
                if (state !== 'expanded') return;
                collapseCycle();
              }, 2000);
            },
          }
        );
      }

      // ── Ciclo de colapso automático ──────────────────────

      function collapseCycle() {
        clearTimer();
        state = 'collapsing';

        const fullH = grid.scrollHeight;
        gsap.set(grid, { maxHeight: fullH });

        gsap.to(grid, {
          maxHeight: 0,
          opacity: 0,
          duration: 0.6,
          ease: 'power2.inOut',
          onComplete: () => {
            if (state !== 'collapsing') return;
            state = 'collapsed';
            gsap.set(grid, { overflow: 'hidden' }); // mantiene el espacio en 0
            gsap.to(btn, { opacity: 1, visibility: 'visible', duration: 0.3 });
            btn.setAttribute('aria-expanded', 'false');
            btn.textContent = 'Ver todo';
          },
        });
      }

      // ── Salida del viewport ──────────────────────────────

      function leaveCycle() {
        // Solo resetear si el usuario NO ha interactuado (toggle)
        if (state === 'collapsed' || state === 'expanding') return;
        resetToHidden();
      }

      // ── Toggle manual "Ver todo" / "Cerrar" ──────────────

      btn.addEventListener('click', () => {
        if (state === 'collapsed') {
          // Expandir
          state = 'expanding';
          btn.setAttribute('aria-expanded', 'true');
          btn.textContent = 'Cerrar';

          // Primero aseguramos que maxHeight parte de 0
          gsap.set(grid, { maxHeight: 0, opacity: 0, overflow: 'hidden' });

          // Forzamos reflow para que GSAP lea el scrollHeight correcto
          // (el contenido ya está en el DOM, solo estaba hidden por maxHeight)
          const targetH = (() => {
            // Medimos con maxHeight temporal = none
            const prev = grid.style.maxHeight;
            grid.style.maxHeight = 'none';
            const h = grid.scrollHeight;
            grid.style.maxHeight = prev;
            return h;
          })();

          gsap.to(grid, {
            maxHeight: targetH,
            opacity: 1,
            duration: 0.55,
            ease: 'power2.out',
            onComplete: () => {
              gsap.set(grid, { maxHeight: 'none' }); // libre para resize
              state = 'expanded';
              // Reiniciar el timer de 2s
              collapseTimeout = setTimeout(() => {
                if (state !== 'expanded') return;
                collapseCycle();
              }, 2000);
            },
          });

        } else if (state === 'expanded' || state === 'expanding') {
          // Colapsar manualmente
          clearTimer();
          collapseCycle();
          btn.setAttribute('aria-expanded', 'true'); // se actualiza en onComplete
        }
      });

      // ── ScrollTrigger ─────────────────────────────────────

      ScrollTrigger.create({
        trigger: col,
        start: 'top 85%',
        end:   'bottom 12%',
        onEnter:     enterCycle,
        onEnterBack: enterCycle,
        onLeave:     leaveCycle,
        onLeaveBack: leaveCycle,
      });

      // Estado inicial
      resetToHidden();
    });
  }

  document.addEventListener('animations:ready', initStack);
</script>

<style>
  .section-pad { padding: 7rem 0; }
  .container   { max-width: 1280px; margin: 0 auto; padding: 0 2rem; }

  /* ── Fila horizontal de 5 columnas ─────────────────────── */
  .stack-row {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.5rem;
    margin-top: 4rem;
    align-items: start;
  }
  @media (max-width: 1100px) {
    .stack-row { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 720px) {
    .stack-row { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 440px) {
    .stack-row { grid-template-columns: 1fr; }
  }

  /* ── Columna ─────────────────────────────────────────────── */
  .stack-col {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .stack-col__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 0.75rem;
    margin-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .stack-col__title {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .stack-col__btn {
    background: none;
    border: none;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    cursor: pointer;
    opacity: 0;
    visibility: hidden;
    transition: color 0.2s;
    padding: 0;
    white-space: nowrap;
  }
  .stack-col__btn:hover { color: var(--color-accent); }

  /* ── Grid interior ──────────────────────────────────────── */
  .stack-col__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(72px, 1fr));
    gap: 0.6rem;
    /* maxHeight controlado por GSAP — no poner aquí */
    overflow: hidden;
  }

  /* ── Tarjeta de ítem ────────────────────────────────────── */
  .stack-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    padding: 0.65rem 0.4rem;
    border-radius: 6px;
    text-align: center;
    cursor: default;
    transition: background 0.25s;
  }
  .stack-item:hover {
    background: rgba(255,255,255,0.04);
  }

  .stack-item__icon {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: filter 0.3s;
  }
  .stack-item:hover .stack-item__icon {
    filter: drop-shadow(0 0 7px var(--c));
  }
  .stack-item__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .stack-item__name {
    font-family: var(--font-display);
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.2;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .stack-item__level {
    font-family: var(--font-mono);
    font-size: 0.52rem;
    color: var(--color-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
</style>