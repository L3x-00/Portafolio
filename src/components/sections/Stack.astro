---
import { stack } from '../../data/stack';
import SectionTitle from '../ui/SectionTitle.astro';

const categories = [
  { key: 'Frontend', title: 'Frontend' },
  { key: 'Backend', title: 'Backend & BD' },
  { key: 'Diseño', title: 'Diseño' },
  { key: 'IA', title: 'IA de Apoyo' },
  { key: 'Cloud', title: 'Cloud & DevOps' }
];
---

<section id="stack" class="stack-section sk-loading">
  <div class="sk-container">
    <SectionTitle label="Herramientas" title="Mi stack tecnológico." align="center" />

    <!-- Fila 1: 3 categorías -->
    <div class="sk-row sk-row--top">
      {categories.slice(0, 3).map((cat) => {
        const items = stack.filter(item => item.category === cat.key);
        if (items.length === 0) return null;

        return (
          <div class="sk-col">
            <div class="sk-header">
              <h3 class="sk-title">{cat.title}</h3>
              <button class="sk-toggle" data-state="closed">Ver todo</button>
            </div>

            <div class="sk-preview">
              {items.slice(0, 4).map((item) => (
                <div class="sk-preview-item" style={`--item-color: ${item.color}`}>
                  <img src={item.icon} alt={item.name} />
                  <span>{item.name}</span>
                </div>
              ))}
              {items.length > 4 && (
                <div class="sk-preview-more">+{items.length - 4}</div>
              )}
            </div>

            <div class="sk-grid-wrap">
              <div class="sk-grid">
                {items.map((item) => (
                  <div class="sk-card" style={`--item-color: ${item.color}`}>
                    <div class="sk-card-icon">
                      <img src={item.icon} alt={item.name} loading="lazy" />
                    </div>
                    <span class="sk-card-name">{item.name}</span>
                    <span class="sk-card-level">{item.level}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Fila 2: 2 categorías (Centradas) -->
    <div class="sk-row sk-row--bottom">
      {categories.slice(3).map((cat) => {
        const items = stack.filter(item => item.category === cat.key);
        if (items.length === 0) return null;

        return (
          <div class="sk-col">
            <div class="sk-header">
              <h3 class="sk-title">{cat.title}</h3>
              <button class="sk-toggle" data-state="closed">Ver todo</button>
            </div>

            <div class="sk-preview">
              {items.slice(0, 4).map((item) => (
                <div class="sk-preview-item" style={`--item-color: ${item.color}`}>
                  <img src={item.icon} alt={item.name} />
                  <span>{item.name}</span>
                </div>
              ))}
              {items.length > 4 && (
                <div class="sk-preview-more">+{items.length - 4}</div>
              )}
            </div>

            <div class="sk-grid-wrap">
              <div class="sk-grid">
                {items.map((item) => (
                  <div class="sk-card" style={`--item-color: ${item.color}`}>
                    <div class="sk-card-icon">
                      <img src={item.icon} alt={item.name} loading="lazy" />
                    </div>
                    <span class="sk-card-name">{item.name}</span>
                    <span class="sk-card-level">{item.level}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        );
      })}
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  window.addEventListener('load', () => {
    document.querySelectorAll<HTMLElement>('.sk-col').forEach((col) => {
      if (col.dataset.animated) return;
      col.dataset.animated = '1';

      const gridWrap  = col.querySelector<HTMLElement>('.sk-grid-wrap')!;
      const toggleBtn = col.querySelector<HTMLButtonElement>('.sk-toggle')!;
      if (!gridWrap || !toggleBtn) return;

      const cards = Array.from(gridWrap.querySelectorAll<HTMLElement>('.sk-card'));
      if (!cards.length) return;

      gsap.set(cards, { opacity: 0, y: 30, scale: 0.95 });
      gsap.set(gridWrap, { height: 0, overflow: 'hidden', opacity: 0 });
      gsap.set(toggleBtn, { opacity: 0, visibility: 'hidden', display: 'block' });

      const section = col.closest<HTMLElement>('.stack-section');
      if (section) section.classList.remove('sk-loading');

      let collapseTimer: ReturnType<typeof setTimeout> | null = null;
      let isAnimating = false;

      function runEnterCycle() {
        if (isAnimating) return;
        isAnimating = true;
        if (collapseTimer) { clearTimeout(collapseTimer); collapseTimer = null; }

        gsap.set(toggleBtn, { opacity: 0, visibility: 'hidden' });
        toggleBtn.dataset.state = 'closed';
        gsap.set(cards, { opacity: 0, y: 30, scale: 0.95 });

        gsap.set(gridWrap, { height: 'auto', opacity: 1, overflow: 'hidden' });
        const targetHeight = gridWrap.scrollHeight;
        gsap.set(gridWrap, { height: 0 });

        gsap.to(gridWrap, { height: targetHeight, opacity: 1, duration: 0.6, ease: 'power3.out' });

        gsap.to(cards, {
          opacity: 1, y: 0, scale: 1,
          duration: 0.5,
          stagger: { amount: 0.4, from: 'start' },
          ease: 'power3.out',
          onComplete: () => {
            collapseTimer = setTimeout(() => {
              if (!isAnimating) return;
              const currentHeight = gridWrap.scrollHeight;
              gsap.set(gridWrap, { height: currentHeight });
              gsap.to(gridWrap, {
                height: 0, opacity: 0, duration: 0.7, ease: 'power3.inOut',
                onComplete: () => {
                  gsap.to(toggleBtn, { opacity: 1, visibility: 'visible', duration: 0.3 });
                  toggleBtn.textContent = 'Ver todo';
                  isAnimating = false;
                },
              });
            }, 2000);
          },
        });
      }

      function runLeaveCycle() {
        isAnimating = false;
        if (collapseTimer) { clearTimeout(collapseTimer); collapseTimer = null; }
        gsap.killTweensOf([gridWrap, ...cards]);
        gsap.to([gridWrap, ...cards], {
          opacity: 0, duration: 0.2, ease: 'power2.in',
          onComplete: () => {
            gsap.set(gridWrap, { height: 0, opacity: 0 });
            gsap.set(cards, { opacity: 0, y: 30, scale: 0.95 });
            gsap.set(toggleBtn, { opacity: 0, visibility: 'hidden' });
          },
        });
      }

      ScrollTrigger.create({
        trigger: col,
        start: 'top 88%', end: 'bottom 10%',
        onEnter: runEnterCycle, onEnterBack: runEnterCycle,
        onLeave: runLeaveCycle, onLeaveBack: runLeaveCycle,
      });

      toggleBtn.addEventListener('click', () => {
        const isOpen = toggleBtn.dataset.state === 'open';
        isAnimating = false;
        if (collapseTimer) { clearTimeout(collapseTimer); collapseTimer = null; }

        if (isOpen) {
          const h = gridWrap.scrollHeight;
          gsap.set(gridWrap, { height: h });
          gsap.to(gridWrap, {
            height: 0, opacity: 0, duration: 0.5, ease: 'power3.inOut',
            onComplete: () => { toggleBtn.textContent = 'Ver todo'; toggleBtn.dataset.state = 'closed'; },
          });
        } else {
          gsap.set(gridWrap, { height: 0, opacity: 0 });
          gsap.set(cards, { opacity: 0, y: 30, scale: 0.95 });
          const targetH = gridWrap.scrollHeight;
          gsap.to(gridWrap, {
            height: targetH, opacity: 1, duration: 0.5, ease: 'power3.out',
            onComplete: () => { gsap.set(gridWrap, { height: 'auto' }); toggleBtn.textContent = 'Cerrar'; toggleBtn.dataset.state = 'open'; },
          });
          gsap.to(cards, { opacity: 1, y: 0, scale: 1, duration: 0.4, stagger: { amount: 0.3, from: 'start' }, ease: 'power3.out' });
        }
      });
    });
  });
</script>

<style is:global>
  /* ━━━ CLASE ANTI-FOUC ━━━ */
  .sk-loading .sk-card {
    opacity: 0 !important;
  }

  /* ━━━ ESTILOS BASE ━━━ */
  .stack-section { padding: 7rem 0; }
  .sk-container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }
  
  /* ━━━ LAYOUT EMBUDO ━━━ */
  .sk-row {
    display: flex;
    justify-content: center;
    gap: 2.5rem;
    flex-wrap: wrap;
  }

  .sk-row--top {
    margin-bottom: 2.5rem; /* Espacio entre la fila de 3 y la de 2 */
  }

  .sk-col {
    flex: 1 1 300px; /* Ancho base, crece si hay espacio */
    max-width: 360px; /* No se pasan de anchas */
    min-width: 250px;
  }

  /* Responsivo */
  @media (max-width: 768px) { 
    .sk-col { flex: 0 1 45%; max-width: none; } /* 2 por fila en tablets */
  }
  @media (max-width: 520px) { 
    .sk-col { flex: 0 1 100%; max-width: none; } /* 1 por fila en móviles */
  }

  .sk-header {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 1.5rem; padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }
  .sk-title {
    font-family: var(--font-mono); font-size: 0.75rem;
    letter-spacing: 0.15em; text-transform: uppercase; color: var(--color-accent);
  }
  .sk-toggle {
    background: none; border: none; color: var(--color-muted);
    font-family: var(--font-mono); font-size: 0.7rem; cursor: pointer;
    opacity: 0; visibility: hidden; transition: color 0.2s ease; padding: 0;
  }
  .sk-toggle:hover { color: var(--color-accent); }

  .sk-preview { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem; }
  .sk-preview-item {
    display: inline-flex; align-items: center; gap: 0.55rem;
    padding: 0; background: transparent; border: none; transition: transform .25s ease;
  }
  .sk-preview-item:hover { transform: translateY(-2px); }
  .sk-preview-item img {
    width: 22px; height: 22px; object-fit: contain;
    transition: filter .3s ease, transform .3s ease;
  }
  .sk-preview-item:hover img {
    transform: scale(1.12);
    filter: drop-shadow(0 0 10px var(--item-color)) drop-shadow(0 0 20px var(--item-color));
  }
  .sk-preview-item span {
    font-size: 0.95rem; font-weight: 500; font-family: var(--font-display);
    color: var(--color-text); white-space: nowrap;
  }
  .sk-preview-more {
    color: var(--color-accent); font-family: var(--font-display);
    font-size: 1rem; font-weight: 700;
  }

  /* ━━━ EL CONTENEDOR DEL GRID DEBE ESTAR OCULTO DESDE EL CSS ━━━ */
  .sk-grid-wrap {
    overflow: hidden;
    height: 0;      
    opacity: 0;     
  }

  .sk-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
    gap: 1rem;
  }
  @media (max-width: 768px) { .sk-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .sk-grid { grid-template-columns: 1fr; } }

  .sk-card {
    display: flex; flex-direction: column; align-items: center; text-align: center;
    gap: 0.5rem; padding: 1rem 0.5rem; border-radius: 6px; background: transparent;
  }
  .sk-card-icon {
    width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;
    color: var(--item-color); transition: filter 0.3s ease;
  }
  .sk-card:hover .sk-card-icon { filter: drop-shadow(0 0 12px var(--item-color)); }
  .sk-card-icon img { width: 100%; height: 100%; object-fit: contain; }
  
  .sk-card-name {
    font-family: var(--font-display); font-size: 0.8rem; font-weight: 600;
    color: var(--color-text); line-height: 1.2;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .sk-card-level {
    font-family: var(--font-mono); font-size: 0.55rem; color: var(--color-muted);
    letter-spacing: 0.05em; text-transform: uppercase;
  }
</style>