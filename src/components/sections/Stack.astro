---
import { stack } from '../../data/stack';
import SectionTitle from '../ui/SectionTitle.astro';

const categories = [
  { key: 'Frontend', title: 'Frontend' },
  { key: 'Backend', title: 'Backend & BD' },
  { key: 'Diseño', title: 'Diseño' },
  { key: 'IA', title: 'IA de Apoyo' }
];
---

<section id="stack" class="stack-section section-pad">
  <div class="container">
    <SectionTitle label="Herramientas" title="Mi stack tecnológico." align="center" />

    <div class="stack-row">
      {categories.map((cat) => {
        const items = stack.filter(item => item.category === cat.key);
        if (items.length === 0) return null;

        return (
          <div class="stack-category-col">
            <!-- Nueva cabecera para alinear título y botón -->
            <div class="stack-cat-header">
              <h3 class="stack-cat-title">{cat.title}</h3>
              <button class="stack-cat-toggle" data-state="closed">
                Ver todo
              </button>
            </div>

            <div class="stack-preview">
              {items.slice(0, 4).map((item) => (
                <div class="stack-preview-item" style={`--item-color: ${item.color}`} >
                  <img src={item.icon} alt={item.name} />
                  <span>{item.name}</span>
                </div>
              ))}

              {items.length > 4 && (
                <div class="stack-preview-more">
                  +{items.length - 4}
                </div>
              )}
            </div>

            <div class="stack-cat-grid">
              {items.map((item) => (
                <div class="stack-item-card" style={`--item-color: ${item.color}`}>
                  <div class="stack-item-icon">
                    <img src={item.icon} alt={item.name} loading="lazy" />
                  </div>
                  <span class="stack-item-name">{item.name}</span>
                  <span class="stack-item-level">{item.level}</span>
                </div>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  function initStackMagic() {
    document.querySelectorAll<HTMLElement>('.stack-category-col:not([data-animated])').forEach((col) => {
      col.dataset.animated = '1';

      const preview  = col.querySelector<HTMLElement>('.stack-preview');
      const grid     = col.querySelector<HTMLElement>('.stack-cat-grid');
      const toggleBtn = col.querySelector<HTMLButtonElement>('.stack-cat-toggle');

      if (!preview || !grid || !toggleBtn) return;

      const cards = Array.from(grid.querySelectorAll<HTMLElement>('.stack-item-card'));

      // Estado inicial: tarjetas ocultas, botón oculto, preview visible
      gsap.set(cards, { opacity: 0, y: 25, scale: 0.92 });
      gsap.set(toggleBtn, { opacity: 0, visibility: 'hidden' });

      // ✅ FIX PRINCIPAL: El timeline SOLO anima la entrada y muestra el botón.
      // Se eliminó el 'tl.to({}, { duration: 2 })' + auto-colapso que era el bug de los 3 segundos.
      ScrollTrigger.create({
        trigger: col,
        start: 'top 85%',
        once: true,
        onEnter: () => {
          // Mostrar grid (estaba hidden por CSS)
          grid.style.display = 'grid';

          // Animar tarjetas
          gsap.to(cards, {
            opacity: 1,
            y: 0,
            scale: 1,
            duration: 0.65,
            stagger: 0.04,
            ease: 'power3.out',
            onComplete: () => {
              // Mostrar botón toggle SOLO después de que terminan las tarjetas
              gsap.to(toggleBtn, {
                opacity: 1,
                visibility: 'visible',
                duration: 0.3,
              });
              toggleBtn.dataset.state = 'open';
              toggleBtn.textContent = 'Cerrar';
            },
          });
        },
      });

      // Toggle: expansión / colapso por click del usuario
      toggleBtn.addEventListener('click', () => {
        const isOpen = toggleBtn.dataset.state === 'open';

        if (isOpen) {
          // Colapsar → mostrar preview
          gsap.to(grid, {
            opacity: 0,
            y: -15,
            duration: 0.4,
            ease: 'power2.inOut',
            onComplete: () => { grid.style.display = 'none'; },
          });
          gsap.fromTo(preview,
            { opacity: 0, y: 10 },
            { opacity: 1, y: 0, duration: 0.35, ease: 'power2.out' }
          );
          toggleBtn.textContent = 'Ver todo';
          toggleBtn.dataset.state = 'closed';
        } else {
          // Expandir → mostrar grid completo
          gsap.to(preview, {
            opacity: 0,
            y: -10,
            duration: 0.3,
            onComplete: () => { preview.style.opacity = '0'; },
          });
          grid.style.display = 'grid';
          gsap.fromTo(grid,
            { opacity: 0, y: 15 },
            { opacity: 1, y: 0, duration: 0.45, ease: 'power2.out' }
          );
          toggleBtn.textContent = 'Cerrar';
          toggleBtn.dataset.state = 'open';
        }
      });
    });
  }

  // ✅ Solo animations:ready
  document.addEventListener('animations:ready', initStackMagic);
</script>