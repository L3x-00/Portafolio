---
interface Props {
  label?: string;
  title: string;
  align?: 'left' | 'center';
}
const { label, title, align = 'left' } = Astro.props;
---

<div class={`section-title section-title--${align}`}>
  {label && <p class="section-title__label">{label}</p>}
  <h2 class="section-title__h2">{title}</h2>
  <div class="section-title__line"></div>
</div>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  function initTitles() {
    document.querySelectorAll<HTMLElement>('.section-title:not([data-st])').forEach((el) => {
      el.dataset.st = '1';
      
      gsap.from(el, {
        y: 30,
        opacity: 0,
        duration: 0.6,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 90%',
          end: 'bottom 20%',    // Mantén el título visible mucho más tiempo
          toggleActions: "play reverse play reverse",
        },
      });
    });
  }

  document.addEventListener('animations:ready', initTitles);
  document.addEventListener('astro:page-load', initTitles);
</script>

<style>
  .section-title { 
    display: flex; 
    flex-direction: column; 
    gap: 0.75rem; 
  }
  
  .section-title--center { 
    align-items: center; 
    text-align: center; 
  }

  .section-title__label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    text-transform: uppercase;
  }

  .section-title__h2 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    background: linear-gradient(135deg, var(--color-text) 0%, var(--color-muted) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-title__line {
    width: 3rem;
    height: 1px;
    background: linear-gradient(90deg, var(--color-accent), transparent);
  }
  
  .section-title--center .section-title__line { 
    margin: 0 auto; 
  }
</style>