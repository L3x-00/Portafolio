---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Portafolio | Desarrollador Frontend & Creativo',
  description = 'Desarrollador Frontend especializado en experiencias web inmersivas con Three.js, GSAP y animaciones cinematográficas.',
} = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <style>
  html,
  body {
    background: #050505;
    margin: 0;
    padding: 0;
  }
</style>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#050505" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="www.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    {/* CAMBIO 1: BORRAR este bloque completo. Esto confunde al navegador al hacer F5 */}
  </head>
  <body>
    <slot />
  </body>
</html>

<script>
  import Lenis from 'lenis';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);
  gsap.ticker.lagSmoothing(0);

  let _lenisTicker: ((time: number) => void) | null = null;

  // Función para actualizar la URL sin recargar (Scroll Spy)
  function updateUrlHash() {
    const sections = document.querySelectorAll('section[id]');
    let currentSection = '';
    
    sections.forEach(section => {
      const sectionTop = (section as HTMLElement).offsetTop - 150;
      if (window.scrollY >= sectionTop) {
        currentSection = section.getAttribute('id') || '';
      }
    });

    if (currentSection && window.location.hash !== `#${currentSection}`) {
      history.replaceState(null, '', `#${currentSection}`);
    } else if (!currentSection && window.location.hash !== '') {
      history.replaceState(null, '', window.location.pathname);
    }
  }
  
  function setupScroll() {
    // --- LIMPIEZA ---
    if (_lenisTicker) {
      gsap.ticker.remove(_lenisTicker);
      _lenisTicker = null;
    }
    const prevLenis = (window as any).__lenis as InstanceType<typeof Lenis> | undefined;
    if (prevLenis) prevLenis.destroy();
    ScrollTrigger.getAll().forEach((t) => t.kill());

    // --- PREFERS-REDUCED-MOTION ---
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) {
      gsap.globalTimeline.timeScale(1);
      Promise.resolve().then(() => {
        document.dispatchEvent(new CustomEvent('animations:ready', { detail: { reduced: true } }));
      });
      return;
    }

    // --- INICIALIZAR LENIS ---
    const lenis = new Lenis({ autoRaf: false });
    
    lenis.on('scroll', () => {
      ScrollTrigger.update();
      updateUrlHash();
    });

    _lenisTicker = (time: number) => lenis.raf(time * 1000);
    gsap.ticker.add(_lenisTicker);
    (window as any).__lenis = lenis;

    // --- INTERCEPTAR CLICKS DEL MENÚ ---
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', (e) => {
        const targetId = anchor.getAttribute('href');
        if (targetId && targetId !== '#') {
          e.preventDefault();
          const targetElement = document.querySelector(targetId as string);
          if (targetElement) {
            lenis.scrollTo(targetElement as HTMLElement, { 
              offset: -80,
              immediate: false 
            });
          }
        }
      });
    });

    // CAMBIO 2: Arreglar el timing. En lugar de un Promise.resolve (que falla con Vite),
    // usamos un setTimeout de 0ms. Esto obliga a esperar a que Vite termine de inyectar 
    // todos los componentes en la página ANTES de dar la orden de animar.
    setTimeout(() => {
      document.dispatchEvent(new CustomEvent('animations:ready', { detail: { reduced: false } }));

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          ScrollTrigger.refresh();
          
          updateUrlHash();
        });
      });
    }, 0);
  }

  // Carga inicial
  setupScroll();

  // Astro View Transitions: re-inicializar en cada navegación interna
  document.addEventListener('astro:page-load', setupScroll);
</script>