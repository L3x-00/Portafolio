---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Portafolio | Desarrollador Frontend & Creativo',
  description = 'Desarrollador Frontend especializado en experiencias web inmersivas con Three.js, GSAP y animaciones cinematográficas.',
} = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#050505" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>html,body{background:#050505;margin:0;padding:0;}</style>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <!-- ✅ FIX Bug 5: era 'www.gstatic.com' sin https, las fuentes no precargaban -->
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body>
    <slot />
  </body>
</html>

<script>
  import Lenis from 'lenis';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);
  gsap.ticker.lagSmoothing(0);

  let _lenisTicker: ((time: number) => void) | null = null;

  function updateUrlHash() {
    const sections = document.querySelectorAll('section[id]');
    let currentSection = '';
    sections.forEach(section => {
      const sectionTop = (section as HTMLElement).offsetTop - 150;
      if (window.scrollY >= sectionTop) {
        currentSection = section.getAttribute('id') || '';
      }
    });
    if (currentSection && window.location.hash !== `#${currentSection}`) {
      history.replaceState(null, '', `#${currentSection}`);
    } else if (!currentSection && window.location.hash !== '') {
      history.replaceState(null, '', window.location.pathname);
    }
  }

  function setupScroll() {
    // Limpieza de instancia anterior
    if (_lenisTicker) {
      gsap.ticker.remove(_lenisTicker);
      _lenisTicker = null;
    }
    const prevLenis = (window as any).__lenis as InstanceType<typeof Lenis> | undefined;
    if (prevLenis) prevLenis.destroy();
    ScrollTrigger.getAll().forEach((t) => t.kill());

    // Limpiar guardas de animaciones para que se reinicialicen en navegación
    document.querySelectorAll('[data-rtext],[data-sg],[data-animated],[data-px]').forEach(el => {
      (el as HTMLElement).removeAttribute('data-rtext');
      (el as HTMLElement).removeAttribute('data-sg');
      (el as HTMLElement).removeAttribute('data-animated');
      (el as HTMLElement).removeAttribute('data-px');
    });

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) {
      gsap.globalTimeline.timeScale(1);
      Promise.resolve().then(() => {
        document.dispatchEvent(new CustomEvent('animations:ready', { detail: { reduced: true } }));
      });
      return;
    }

    const lenis = new Lenis({ autoRaf: false });

    lenis.on('scroll', () => {
      ScrollTrigger.update();
      updateUrlHash();
    });

    _lenisTicker = (time: number) => lenis.raf(time * 1000);
    gsap.ticker.add(_lenisTicker);
    (window as any).__lenis = lenis;

    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', (e) => {
        const targetId = anchor.getAttribute('href');
        if (targetId && targetId !== '#') {
          e.preventDefault();
          const targetElement = document.querySelector(targetId as string);
          if (targetElement) {
            lenis.scrollTo(targetElement as HTMLElement, { offset: -80, immediate: false });
          }
        }
      });
    });

    // ✅ FIX Bug 4: Promise.resolve garantiza que todos los scripts de componentes
    // ya registraron sus listeners ANTES de que disparemos 'animations:ready'.
    // Se eliminó setupScroll() inicial — astro:page-load ya cubre la carga inicial en Astro 6.
    Promise.resolve().then(() => {
      document.dispatchEvent(new CustomEvent('animations:ready', { detail: { reduced: false } }));
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          ScrollTrigger.refresh();
          updateUrlHash();
        });
      });
    });
  }

  // ✅ FIX Bug 4: En Astro 6 con <ClientRouter />, 'astro:page-load' se dispara
  // en la carga inicial Y en cada navegación. Ya no necesitamos llamar setupScroll() manualmente.
  document.addEventListener('astro:page-load', setupScroll);
</script>