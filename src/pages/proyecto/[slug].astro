---
import { projects } from '../../data/projects';
import type { Project } from '../../types';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/ui/Navbar.astro';
import Footer from '../../components/ui/Footer.astro';
import Button from '../../components/ui/Button.astro';

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props:  { project },
  }));
}

interface Props { project: Project }
const { project } = Astro.props;
---

<Layout title={`${project.title} | Portafolio`} description={project.description}>
  <Navbar />

  <main class="project-main">
    <article class="project-article">

      <header class="project-header container">
        <div class="project-header__meta">
          <a href="/#proyectos" class="project-back">← Volver</a>
          <span class="project-year">{project.year}</span>
        </div>
        <h1 class="project-title">{project.title}</h1>
        
        {/* ━━━ STACK TECNOLÓGICO CON SVG REALES ━━━ */}
        <div class="project-stack">
          {project.tags.map(tag => (
            <div class="stack-item">
              <img src={`/icons/${tag}-color.svg`} alt={tag} class="stack-item__icon" />
              {/* Capitalizar la primera letra para que se vea mejor (php -> Php) */}
              <span class="stack-item__name">{tag.charAt(0).toUpperCase() + tag.slice(1)}</span>
            </div>
          ))}
        </div>

      </header>

      <div class="project-hero-image">
        <img src={project.image} alt={project.title} />
      </div>

      <div class="project-body container">
        <div class="project-desc">
          <h2 class="project-section-title">El proyecto</h2>
          <p class="project-long-desc">{project.longDesc}</p>
        </div>

        <div class="project-actions">
          <Button text="Ver en vivo →" href={project.url} variant="primary" target="_blank" />
        </div>
      </div>

    </article>
  </main>

  <Footer />
</Layout>

<style is:global>
  .project-main {
    padding-top: 6rem;
    min-height: 100dvh;
  }
  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .project-header {
    padding-top: 3rem;
    padding-bottom: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .project-header__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .project-back {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-muted);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: color 0.2s;
  }
  .project-back:hover { color: var(--color-accent); }

  .project-year {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
    letter-spacing: 0.1em;
  }

  .project-title {
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.05;
  }

  /* ━━━ STACK TECNOLÓGICO (Horizontal, sin bordes) ━━━ */
  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin-top: 0.5rem;
  }

  .stack-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: default;
  }

  .stack-item__icon {
    width: 24px; /* Tamaño del icono */
    height: 24px;
    object-fit: contain;
    filter: brightness(0.85);
    transition: filter 0.3s ease, transform 0.3s ease;
  }

  .stack-item:hover .stack-item__icon {
    filter: brightness(1.2) drop-shadow(0 0 6px currentColor); /* Brilla cyan al hover */
    transform: scale(1.15); /* Crece un poco */
  }

  .stack-item__name {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-muted);
    letter-spacing: 0.02em;
    transition: color 0.3s ease;
  }

  .stack-item:hover .stack-item__name {
    color: var(--color-text); /* Se pone blanco al hover */
  }

  .project-hero-image {
    width: 100%;
    aspect-ratio: 16/7;
    overflow: hidden;
  }
  .project-hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-body {
    padding-top: 4rem;
    padding-bottom: 6rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .project-section-title {
    font-size: 0.85rem; /* Un poco más pequeño y elegante */
    font-family: var(--font-mono);
    letter-spacing: 0.15em; /* Más espaciado */
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  /* Línea decorativa después del título */
  .project-section-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--color-border), transparent);
  }

  .project-long-desc {
    font-size: 1.125rem;
    color: var(--color-muted);
    line-height: 1.9;
    max-width: 720px;
  }

  .project-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
</style>